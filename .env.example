# ============================================================
# Environment Variables - copy this file to .env.local
# ============================================================

# Email service (used in src/lib/actions.ts for contact form)
# Sign up at https://resend.com to get an API key
RESEND_API_KEY=your_resend_api_key_here

# Site URL (used for metadata/SEO, update for production)
NEXT_PUBLIC_SITE_URL=https://darshanhd.dev

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=

# Optional: Formspree endpoint (alternative to Resend)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
